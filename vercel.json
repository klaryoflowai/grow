{
  "rewrites": [
    {
      "source": "/api/telegram-webhook-setup",
      "destination": "/api/telegram-admin?action=setup"
    },
    {
      "source": "/api/telegram-webhook-info",
      "destination": "/api/telegram-admin?action=info"
    }
  ],
  "crons": [
    {
      "path": "/api/telegram-evening?weeklyReview=1",
      "schedule": "0 15 * * 5"
    },
    {
      "path": "/api/telegram-evening?weeklyReview=1",
      "schedule": "0 16 * * 5"
    }
  ]
}
